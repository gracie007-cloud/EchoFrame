## 🟦 Node.js / TypeScript SDK (`zod` + native `fetch`)

```bash
npm install zod
```

```typescript
// src/aethel.ts
import { z } from 'zod';

// --- SCHEMA DEFINITIONS ---
const metaSchema = z.object({
  project_id: z.string().uuid().optional(),
  cli_version: z.string().default('1.0.0'),
  execution_mode: z.enum(['sync', 'async', 'dry_run']).default('sync'),
  priority: z.enum(['low', 'normal', 'high', 'critical']).default('normal'),
  output_dir: z.string().optional(),
});

const baseParamSchema = z.object({ '@op': z.string() }).strict();

const initSchema = baseParamSchema.extend({ '@op': z.literal('init_project'), name: z.string().min(2), subject_type: z.enum(['human', 'animal', 'mythical', 'fictional', 'artifact']) });
const scriptSchema = baseParamSchema.extend({ '@op': z.literal('generate_script'), length_seconds: z.number().int().min(30).max(1200), tone_profile: z.enum(['scholarly', 'intimate', 'dramatic', 'mythic', 'reflective']).optional() });
const voiceSchema = baseParamSchema.extend({ '@op': z.literal('synthesize_voice'), voice_type: z.enum(['clone', 'acoustic_design', 'prescribed_profile']), clone_consent_hash: z.string().regex(/^[a-f0-9]{64}$/).optional(), acoustic_design: z.record(z.unknown()).optional() });
const renderSchema = baseParamSchema.extend({ '@op': z.literal('start_render'), resolution: z.enum(['720p', '1080p', '4K']).default('1080p'), fps: z.enum([24, 30, 60]).default(30) });
const exportSchema = baseParamSchema.extend({ '@op': z.literal('export_video'), container_format: z.enum(['mp4_h264', 'mp4_h265', 'webm_vp9']).default('mp4_h265'), accessibility_tracks: z.record(z.boolean()).optional(), provenance: z.record(z.boolean()).optional() });

const paramsSchema = z.discriminatedUnion('@op', [initSchema, scriptSchema, voiceSchema, renderSchema, exportSchema]);

export const commandSchema = z.object({
  meta: metaSchema,
  operation: z.enum(['init_project', 'generate_script', 'configure_avatar', 'synthesize_voice', 'compose_scene', 'start_render', 'export_video', 'queue_status']),
  parameters: paramsSchema,
}).strict();

export type AethelCommand = z.infer<typeof commandSchema>;
export type AethelResponse = { status: string; job_id?: string; results?: unknown; error?: string };

// --- CLIENT ---
export class AethelSDK {
  constructor(private baseUrl: string, private apiKey: string, private timeoutMs = 30000) {}

  private async request<T>(endpoint: string, payload: AethelCommand): Promise<T> {
    const validated = commandSchema.parse(payload);
    
    if (validated.meta.execution_mode === 'dry_run') {
      return { status: 'dry_run', validated_payload: validated } as unknown as T;
    }

    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), this.timeoutMs);

    try {
      const res = await fetch(`${this.baseUrl}${endpoint}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${this.apiKey}` },
        body: JSON.stringify(validated, null, 2),
        signal: controller.signal
      });
      if (!res.ok) throw new Error(`HTTP ${res.status}: ${await res.text()}`);
      return res.json() as Promise<T>;
    } finally {
      clearTimeout(timeoutId);
    }
  }

  async run(command: AethelCommand): Promise<AethelResponse> {
    return this.request<AethelResponse>('/v1/pipeline', command);
  }

  // Fluent builders
  static init(name: string, subject_type: AethelCommand['parameters'] extends infer P ? P extends { subject_type: infer ST } ? ST : never : never, opts?: Partial<AethelCommand['meta']>): AethelCommand {
    return { meta: { ...opts }, operation: 'init_project', parameters: { '@op': 'init_project', name, subject_type } };
  }

  static voice(voice_type: 'clone' | 'acoustic_design' | 'prescribed_profile', opts?: { acoustic_design?: Record<string, unknown>, prosody_settings?: Record<string, unknown> }): AethelCommand {
    return { meta: {}, operation: 'synthesize_voice', parameters: { '@op': 'synthesize_voice', voice_type, ...opts } };
  }

  static export(fmt: 'mp4_h264' | 'mp4_h265' | 'webm_vp9' = 'mp4_h265', opts?: { accessibility_tracks?: Record<string, boolean>, provenance?: Record<string, boolean> }): AethelCommand {
    return { meta: {}, operation: 'export_video', parameters: { '@op': 'export_video', container_format: fmt, ...opts } };
  }
}
```

