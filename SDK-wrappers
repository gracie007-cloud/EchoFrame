Here are production-ready SDK wrappers for both **Python** and **Node.js/TypeScript**. Both enforce the JSON schema at runtime, provide type-safe builders, and handle async execution with validation.

---

## 🐍 Python SDK (Pydantic v2 + `httpx`)

```bash
pip install pydantic httpx
```

```python
# aethel_sdk/__init__.py
from __future__ import annotations
from pydantic import BaseModel, Field, ConfigDict
from typing import Literal, Optional, Dict, Any, Union
import httpx
import asyncio
from datetime import datetime

# --- SCHEMA MODELS ---
class Meta(BaseModel):
    model_config = ConfigDict(extra="forbid")
    project_id: Optional[str] = None
    cli_version: str = "1.0.0"
    execution_mode: Literal["sync", "async", "dry_run"] = "sync"
    priority: Literal["low", "normal", "high", "critical"] = "normal"
    output_dir: Optional[str] = None

class InitParams(BaseModel):
    model_config = ConfigDict(extra="forbid", populate_by_name=True)
    op: Literal["init_project"] = Field(alias="@op", default="init_project")
    name: str
    subject_type: Literal["human", "animal", "mythical", "fictional", "artifact"]
    target_language: str = "en-US"
    source_data: Optional[Dict[str, Any]] = None

class ScriptParams(BaseModel):
    model_config = ConfigDict(extra="forbid", populate_by_name=True)
    op: Literal["generate_script"] = Field(alias="@op", default="generate_script")
    length_seconds: int = Field(ge=30, le=1200)
    narrative_structure: Literal["three_act", "chronological", "thematic"] = "three_act"
    tone_profile: Optional[Literal["scholarly", "intimate", "dramatic", "mythic", "reflective"]] = None
    accuracy_mode: Literal["verified_only", "speculative_inline", "creative_fiction"] = "speculative_inline"

class VoiceParams(BaseModel):
    model_config = ConfigDict(extra="forbid", populate_by_name=True)
    op: Literal["synthesize_voice"] = Field(alias="@op", default="synthesize_voice")
    voice_type: Literal["clone", "acoustic_design", "prescribed_profile"]
    clone_consent_hash: Optional[str] = Field(default=None, pattern=r"^[a-f0-9]{64}$")
    acoustic_design: Optional[Dict[str, Any]] = None
    prosody_settings: Optional[Dict[str, Any]] = None

class RenderParams(BaseModel):
    model_config = ConfigDict(extra="forbid", populate_by_name=True)
    op: Literal["start_render"] = Field(alias="@op", default="start_render")
    resolution: Literal["720p", "1080p", "4K"] = "1080p"
    fps: Literal[24, 30, 60] = 30
    render_quality: Literal["fast_preview", "balanced", "cinematic_high"] = "balanced"
    gpu_preference: Literal["auto", "cuda", "metal", "webgl_fallback"] = "auto"

class ExportParams(BaseModel):
    model_config = ConfigDict(extra="forbid", populate_by_name=True)
    op: Literal["export_video"] = Field(alias="@op", default="export_video")
    container_format: Literal["mp4_h264", "mp4_h265", "webm_vp9"] = "mp4_h265"
    accessibility_tracks: Optional[Dict[str, Any]] = None
    provenance: Optional[Dict[str, Any]] = None

# Discriminated union for parameters
AllParams = Union[InitParams, ScriptParams, VoiceParams, RenderParams, ExportParams]

class Command(BaseModel):
    model_config = ConfigDict(extra="forbid", populate_by_name=True)
    meta: Meta
    operation: Literal["init_project", "generate_script", "configure_avatar", "synthesize_voice", 
                       "compose_scene", "start_render", "export_video", "queue_status"]
    parameters: AllParams = Field(discriminator="op")

# --- CLIENT ---
class AethelClient:
    def __init__(self, base_url: str, api_key: str, timeout: float = 30.0):
        self.base_url = base_url.rstrip("/")
        self.client = httpx.AsyncClient(
            base_url=self.base_url,
            headers={"Authorization": f"Bearer {api_key}", "Content-Type": "application/json"},
            timeout=timeout
        )

    async def execute(self, command: Command) -> Dict[str, Any]:
        """Validate & dispatch command. Returns API response."""
        payload = command.model_dump(by_alias=True, exclude_none=True)
        
        if command.meta.execution_mode == "dry_run":
            return {"status": "dry_run", "validated_payload": payload}
            
        response = await self.client.post("/v1/pipeline", json=payload)
        response.raise_for_status()
        return response.json()

    def __await__(self):
        return self.client.aclose().__await__()
        
    async def close(self):
        await self.client.aclose()

# Factory helpers for clean usage
class Aethel:
    @staticmethod
    def init(name: str, subject_type: str, **kwargs) -> Command:
        return Command(meta=Meta(), operation="init_project", parameters=InitParams(name=name, subject_type=subject_type, **kwargs))

    @staticmethod
    def script(seconds: int, tone: str = "intimate", **kwargs) -> Command:
        return Command(meta=Meta(), operation="generate_script", parameters=ScriptParams(length_seconds=seconds, tone_profile=tone, **kwargs))

    @staticmethod
    def voice(voice_type: str, acoustic_design: Dict = None, **kwargs) -> Command:
        return Command(meta=Meta(), operation="synthesize_voice", parameters=VoiceParams(voice_type=voice_type, acoustic_design=acoustic_design, **kwargs))

    @staticmethod
    def export(fmt: str = "mp4_h265", **kwargs) -> Command:
        return Command(meta=Meta(), operation="export_video", parameters=ExportParams(container_format=fmt, **kwargs))

    @staticmethod
    def render(res: str = "1080p", fps: int = 30, **kwargs) -> Command:
        return Command(meta=Meta(), operation="start_render", parameters=RenderParams(resolution=res, fps=fps, **kwargs))
```

