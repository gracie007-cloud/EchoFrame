## 📖 Usage Examples

### Python Async Workflow
```python
import asyncio
from aethel_sdk import Aethel, AethelClient

async def main():
    client = AethelClient("https://api.aethelframe.ai", "sk_live_...")
    
    # 1. Validate & Dry Run
    cmd = Aethel.init("Odin's Raven", "mythical", target_language="en-GB")
    print(await client.execute(cmd))

    # 2. Async Pipeline Execution
    voice_cmd = Aethel.voice(
        voice_type="acoustic_design",
        acoustic_design={
            "base_timbre": "baritone",
            "harmonic_layers": 2,
            "spectral_filters": ["avian_chirp", "ethereal_choir"]
        },
        prosody_settings={"pitch_variation": 0.9, "tempo_multiplier": 0.8}
    )
    
    print("Dispatching voice job...")
    resp = await client.execute(voice_cmd)
    print(f"Job ID: {resp.get('job_id')}")

    await client.close()

asyncio.run(main())
```

### TypeScript/Node.js Workflow
```typescript
import { AethelSDK, commandSchema } from './aethel';

const sdk = new AethelSDK('https://api.aethelframe.ai', 'sk_live_...');

async function runPipeline() {
  // Safe construction with full Zod validation
  const payload = {
    meta: { execution_mode: 'async' as const, priority: 'high' as const },
    operation: 'export_video' as const,
    parameters: {
      '@op': 'export_video' as const,
      container_format: 'mp4_h265',
      accessibility_tracks: { captions_vtt: true, audio_description: true },
      provenance: { embed_c2pa: true, visible_watermark: false }
    }
  };

  try {
    // Throws detailed ZodError if schema is violated
    const result = await sdk.run(payload);
    console.log(`✅ Render dispatched: ${result.job_id}`);
  } catch (err) {
    if (err instanceof Error && 'name' in err && err.name === 'ZodError') {
      console.error('❌ Schema Violation:', JSON.stringify(err.issues, null, 2));
    } else {
      throw err;
    }
  }
}

runPipeline();
```

