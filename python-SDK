## 🐍 2. SDK Runner Script (`ci/aethel_runner.py`)

```python
#!/usr/bin/env python3
# ci/aethel_runner.py
"""
AethelFrame CI/CD Runner (SDK-Integrated)
Usage: python ci/aethel_runner.py [dispatch | poll | download]
"""
import os, sys, json, time, asyncio, httpx
from pathlib import Path
from pydantic import ValidationError
import logging

# Configure logging
logging.basicConfig(level=logging.INFO, format="%(asctime)s [%(levelname)s] %(message)s")
logger = logging.getLogger("aethel_ci")

# Import SDK (adjust if using local path)
try:
    from aethel_sdk import AethelClient, Command, Meta
except ImportError:
    logger.error("SDK not installed. Run: pip install aethel-sdk")
    sys.exit(1)

# GitHub Actions helpers
def set_output(key: str, value: str):
    with open(os.environ.get("GITHUB_OUTPUT", "/dev/null"), "a") as f:
        f.write(f"{key}={value}\n")

def get_env(name: str, default: str = "") -> str:
    return os.getenv(name, default)

# SDK Client setup
async def get_client() -> AethelClient:
    return AethelClient(
        base_url=get_env("AETHEL_BASE_URL"),
        api_key=get_env("AETHEL_API_KEY")
    )

# Load & validate payload
def build_command() -> Command:
    quality = get_env("CI_QUALITY", "balanced")
    subject = get_env("CI_SUBJECT", "CI_Subject")
    
    # Base payload from config file or defaults
    try:
        with open("config/pipeline.json", "r") as f:
            payload = json.load(f)
    except FileNotFoundError:
        payload = {
            "operation": "init_project",
            "parameters": {
                "@op": "init_project",
                "name": subject,
                "subject_type": "mythical",
                "target_language": "en-US"
            }
        }

    # Inject CI overrides
    if "parameters" not in payload: payload["parameters"] = {}
    payload["meta"] = {"execution_mode": "async", "priority": "high"}
    payload["operation"] = "start_render"
    payload["parameters"]["@op"] = "start_render"
    payload["parameters"]["render_quality"] = quality

    try:
        return Command.model_validate(payload)
    except ValidationError as e:
        logger.error(f"Schema validation failed:\n{e.json()}")
        sys.exit(1)

# STEP 1: Dispatch
async def cmd_dispatch():
    client = await get_client()
    cmd = build_command()
    
    try:
        logger.info("📤 Dispatching async render job...")
        resp = await client.execute(cmd)
        job_id = resp.get("job_id")
        if not job_id: raise ValueError("API returned no job_id")
        
        set_output("job_id", job_id)
        set_output("status", "dispatched")
        logger.info(f"✅ Job dispatched: {job_id}")
    except Exception as e:
        logger.error(f"❌ Dispatch failed: {e}")
        sys.exit(1)

# STEP 2: Poll with exponential backoff
async def cmd_poll():
    job_id = get_env("JOB_ID")
    if not job_id: raise ValueError("JOB_ID env var required")
    
    client = await get_client()
    timeout_sec = int(get_env("POLL_TIMEOUT_MIN", "240")) * 60
    backoff_base = int(get_env("RETRY_BACKOFF_BASE", "10"))
    backoff_max = int(get_env("RETRY_BACKOFF_MAX", "120"))
    
    elapsed = 0
    backoff = backoff_base
    
    logger.info(f"⏳ Polling job {job_id} (timeout: {timeout_sec//60}m)")
    while elapsed < timeout_sec:
        # SDK polling endpoint (simulated structure)
        status_resp = await client._get_status(job_id) 
        
        stage = status_resp.get("stage", "unknown")
        progress = status_resp.get("progress", 0)
        state = status_resp.get("status", "running")
        
        logger.info(f"📊 [{progress:3d}%] Stage: {stage:10s} | Status: {state}")
        
        if state == "completed":
            logger.info("✅ Render completed successfully.")
            return
        elif state in ("failed", "cancelled"):
            err = status_resp.get("error", {})
            logger.error(f"❌ Job {state}: {err.get('message', 'Unknown')}")
            sys.exit(1)
            
        await asyncio.sleep(backoff)
        elapsed += backoff
        backoff = min(backoff * 1.5, backoff_max)
        
    logger.error("⏱️ Poll timeout exceeded. Job may still be processing.")
    sys.exit(1)

# STEP 3: Download & Verify
async def cmd_download():
    job_id = get_env("JOB_ID")
    out_dir = Path("./aethel_output")
    out_dir.mkdir(exist_ok=True)
    
    logger.info("📥 Downloading artifacts...")
    client = await get_client()
    
    try:
        artifacts = await client._get_artifact_urls(job_id)
        
        for key, url in artifacts.items():
            if not url: continue
            filename = out_dir / f"render_{key.replace('video_url', 'mp4').replace('captions_srt', 'srt')}"
            logger.info(f"  ⬇️ Downloading {key} -> {filename.name}")
            async with httpx.AsyncClient() as dl:
                async with dl.stream("GET", url) as r:
                    r.raise_for_status()
                    with open(filename, "wb") as f:
                        async for chunk in r.aiter_bytes():
                            f.write(chunk)
                            
        logger.info("✅ Artifacts saved to ./aethel_output/")
    except Exception as e:
        logger.error(f"❌ Download failed: {e}")
        sys.exit(1)

if __name__ == "__main__":
    if len(sys.argv) < 2:
        print("Usage: python ci/aethel_runner.py [dispatch | poll | download]")
        sys.exit(1)
        
    action = sys.argv[1]
    actions = {"dispatch": cmd_dispatch, "poll": cmd_poll, "download": cmd_download}
    if action not in actions:
        print(f"Valid actions: {', '.join(actions.keys())}")
        sys.exit(1)
    asyncio.run(actions[action]())
```

