## 🔄 Paired GitHub Actions: `finalize.yml`

```yaml
name: 📦 Aethel Finalize (Webhook Triggered)
on:
  repository_dispatch:
    types: [aethel_job_completed, aethel_job_failed]

jobs:
  finalize:
    runs-on: ubuntu-latest
    env:
      AETHEL_API_KEY: ${{ secrets.AETHEL_API_KEY }}
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with: { python-version: '3.11' }
      - run: pip install aethel-sdk httpx

      - name: 🚨 Handle Failure
        if: github.event.action == 'aethel_job_failed'
        run: |
          echo "::error::Job ${{ github.event.client_payload.job_id }} failed"
          echo "Error: ${{ toJson(github.event.client_payload.error) }}"
          exit 1

      - name: 📥 Download Artifacts
        if: github.event.action == 'aethel_job_completed'
        run: |
          python -c "
          import httpx, os, json
          from pathlib import Path
          Path('aethel_output').mkdir(exist_ok=True)
          job_id = '${{ github.event.client_payload.job_id }}'
          artifacts = json.loads('${{ toJson(github.event.client_payload.artifacts) }}')
          for k, url in artifacts.items():
              print(f'Downloading {k}...')
              r = httpx.get(url, follow_redirects=True)
              r.raise_for_status()
              Path(f'aethel_output/{k}').write_bytes(r.content)
          "

      - name: 📤 Upload to GitHub
        uses: actions/upload-artifact@v4
        with:
          name: aethel-${{ github.event.client_payload.job_id }}
          path: ./aethel_output/
          retention-days: 30
```

