## 🟦 Node.js/TypeScript Implementation (`src/index.ts`)

```typescript
import express, { Request, Response, NextFunction } from 'express';
import crypto from 'crypto';
import { z } from 'zod';
import { createClient } from 'redis';
import cors from 'cors';
import dotenv from 'dotenv';

dotenv.config();

const app = express();
app.use(express.json({ limit: '1mb' }));
app.use(cors({ origin: false })); // Restrict in prod

// --- Config ---
const WEBHOOK_SECRET = process.env.AETHEL_WEBHOOK_SECRET!;
const GITHUB_PAT = process.env.GITHUB_PAT!;
const GITHUB_REPO = process.env.GITHUB_REPOSITORY!; // owner/repo
const REDIS_URL = process.env.REDIS_URL;

if (!WEBHOOK_SECRET || !GITHUB_PAT || !GITHUB_REPO) {
  throw new Error('Missing required environment variables');
}

// --- Idempotency Store ---
let redis: ReturnType<typeof createClient> | undefined;
if (REDIS_URL) {
  redis = createClient({ url: REDIS_URL });
  redis.connect().catch(console.error);
}

async function isIdempotent(id: string): Promise<boolean> {
  const key = `aethel:evt:${id}`;
  if (redis) {
    const exists = await redis.exists(key);
    if (!exists) await redis.set(key, '1', { EX: 86400 }); // 24h TTL
    return exists === 0;
  }
  // Fallback in-memory cache (not production-safe for scaled deployments)
  return false; 
}

// --- Schema Validation ---
const webhookPayloadSchema = z.object({
  id: z.string(),
  type: z.string(),
  time: z.string().datetime(),
  data: z.object({
    job_id: z.string(),
    project_id: z.string().optional(),
    status: z.string().optional(),
    progress_pct: z.number().optional(),
    error: z.object({ code: z.string(), message: z.string() }).optional(),
    artifacts: z.record(z.string()).optional()
  })
});

// --- Signature Verification ---
function verifySignature(req: Request, res: Response, next: NextFunction) {
  const timestamp = req.headers['x-aethel-timestamp'] as string;
  const signature = req.headers['x-aethel-signature'] as string;

  if (!timestamp || !signature) {
    return res.status(400).json({ error: 'Missing security headers' });
  }

  // Replay protection
  if (Math.abs(Date.now() / 1000 - Number(timestamp)) > 300) {
    return res.status(400).json({ error: 'Timestamp expired' });
  }

  const payload = JSON.stringify(req.body);
  const expected = `v1=sha256=${crypto
    .createHmac('sha256', WEBHOOK_SECRET)
    .update(`${timestamp}.${payload}`)
    .digest('hex')}`;

  if (!crypto.timingSafeEqual(Buffer.from(signature), Buffer.from(expected))) {
    return res.status(401).json({ error: 'Invalid signature' });
  }

  next();
}

// --- GitHub Dispatcher ---
async function triggerGitHubDispatch(eventType: string, payload: Record<string, unknown>) {
  const url = `https://api.github.com/repos/${GITHUB_REPO}/dispatches`;
  const response = await fetch(url, {
    method: 'POST',
    headers: {
      Authorization: `Bearer ${GITHUB_PAT}`,
      Accept: 'application/vnd.github+json',
      'X-GitHub-Api-Version': GITHUB_API_VERSION,
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({ event_type: eventType, client_payload: payload })
  });

  if (!response.ok) {
    const errText = await response.text();
    throw new Error(`GitHub API ${response.status}: ${errText}`);
  }

  console.log(`✅ Dispatched ${eventType} to ${GITHUB_REPO}`);
}

// --- Route ---
app.post('/webhook', verifySignature, async (req: Request, res: Response) => {
  try {
    const event = webhookPayloadSchema.parse(req.body);

    // Idempotency check
    if (!await isIdempotent(event.id)) {
      console.log(`⏭️ Duplicate event: ${event.id}`);
      return res.status(200).json({ status: 'ignored_duplicate' });
    }

    // Route by type
    switch (event.type) {
      case 'job.completed':
        await triggerGitHubDispatch('aethel_job_completed', {
          job_id: event.data.job_id,
          project_id: event.data.project_id,
          artifacts: event.data.artifacts,
          duration_sec: event.data.progress_pct // map appropriately if needed
        });
        break;

      case 'job.failed':
        await triggerGitHubDispatch('aethel_job_failed', {
          job_id: event.data.job_id,
          project_id: event.data.project_id,
          error: event.data.error
        });
        break;

      default:
        console.log(`ℹ️ Ignored event type: ${event.type}`);
    }

    res.status(200).json({ status: 'received', event_id: event.id });
  } catch (err) {
    console.error('❌ Webhook handler error:', err);
    // Return 200 to prevent AethelFrame retries, but log for DLQ inspection
    res.status(200).json({ status: 'logged_error' });
  }
});

app.get('/health', (_, res) => res.json({ status: 'ok', uptime: process.uptime() }));

const PORT = Number(process.env.PORT) || 3000;
app.listen(PORT, () => console.log(`🌉 Bridge listening on :${PORT}`));
```

