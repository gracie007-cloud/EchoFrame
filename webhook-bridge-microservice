# main.py
from fastapi import FastAPI, Request, Header, HTTPException
import hmac, hashlib, time, os, httpx, asyncio
from redis.asyncio import Redis
from pydantic import BaseModel
import uvicorn

app = FastAPI()
SECRET = os.environ["AETHEL_WEBHOOK_SECRET"]
GITHUB_PAT = os.environ["GITHUB_PAT"]
GITHUB_REPO = os.environ["GITHUB_REPOSITORY"]
redis = Redis.from_url(os.environ.get("REDIS_URL", "redis://localhost:6379"))

class WebhookPayload(BaseModel):
    id: str
    type: str
    data: dict

async def is_idempotent(eid: str) -> bool:
    exists = await redis.get(f"aethel:evt:{eid}")
    if not exists:
        await redis.setex(f"aethel:evt:{eid}", 86400, "1")
    return bool(exists)

@app.post("/webhook")
async def handle(req: Request, x_aethel_timestamp: str = Header(...), x_aethel_signature: str = Header(...)):
    body = await req.body()
    ts = x_aethel_timestamp.decode()
    if abs(time.time() - float(ts)) > 300: raise HTTPException(400, "Expired timestamp")
    msg = f"{ts}.{body.decode()}"
    expected = f"v1=sha256={hmac.new(SECRET.encode(), msg.encode(), hashlib.sha256).hexdigest()}"
    if not hmac.compare_digest(x_aethel_signature.decode(), expected):
        raise HTTPException(401, "Invalid signature")
        
    payload = WebhookPayload.model_validate_json(body)
    if await is_idempotent(payload.id):
        return {"status": "ignored_duplicate"}
        
    async with httpx.AsyncClient() as client:
        res = await client.post(
            f"https://api.github.com/repos/{GITHUB_REPO}/dispatches",
            headers={"Authorization": f"Bearer {GITHUB_PAT}", "Accept": "application/vnd.github+json"},
            json={"event_type": f"aethel_{payload.type.replace('.', '_')}", "client_payload": payload.data}
        )
        res.raise_for_status()
        
    return {"status": "dispatched"}
