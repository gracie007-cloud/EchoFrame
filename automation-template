## 🐍 `scripts/aethel_runner.py`

```python
#!/usr/bin/env python3
"""
AethelFrame CI/CD Runner
Handles dispatch, polling, C2PA verification, and artifact export.
Integrates with GitHub Actions via GITHUB_OUTPUT & GITHUB_ENV.
"""
import os, sys, json, time, httpx, hashlib
from pathlib import Path
from pydantic import ValidationError
# Assumes aethel_sdk models are available or inline validation is used

BASE_URL = os.getenv("AETHEL_BASE_URL", "https://api.aethelframe.ai")
API_KEY = os.getenv("AETHEL_API_KEY")
JOB_ID = os.getenv("JOB_ID")
DRY_RUN = os.getenv("DRY_RUN", "false").lower() == "true"
QUALITY = os.getenv("QUALITY", "balanced")
SUBJECT = os.getenv("SUBJECT", "CI_Subject")
OUTPUT_DIR = Path("./aethel_output")
OUTPUT_DIR.mkdir(exist_ok=True)

def set_output(key: str, value: str):
    with open(os.environ["GITHUB_OUTPUT"], "a") as f:
        f.write(f"{key}={value}\n")

def build_payload():
    """Constructs the pipeline JSON from CI context."""
    return {
        "meta": {"execution_mode": "dry_run" if DRY_RUN else "async", "priority": "high"},
        "operation": "init_project",
        "parameters": {
            "@op": "init_project",
            "name": SUBJECT,
            "subject_type": "mythical",
            "target_language": "en-US"
        }
    }

def dispatch():
    """Step 1: Validate schema & submit to AethelFrame."""
    payload = build_payload()
    headers = {"Authorization": f"Bearer {API_KEY}", "Content-Type": "application/json"}
    
    try:
        resp = httpx.post(f"{BASE_URL}/v1/pipeline", json=payload, headers=headers, timeout=30)
        resp.raise_for_status()
        data = resp.json()
        
        if DRY_RUN:
            print("✅ Dry run passed. Schema validated.")
            set_output("status", "skipped_dry_run")
            sys.exit(0)
            
        job_id = data.get("job_id")
        set_output("job_id", job_id)
        print(f"✅ Job dispatched: {job_id}")
    except Exception as e:
        print(f"❌ Dispatch failed: {e}")
        sys.exit(1)

def poll():
    """Step 2: Poll API until job completes or timeout."""
    headers = {"Authorization": f"Bearer {API_KEY}"}
    elapsed = 0
    backoff = 10
    
    while elapsed < int(os.getenv("AETHEL_MAX_WAIT_MIN", 180)) * 60:
        try:
            resp = httpx.get(f"{BASE_URL}/v1/jobs/{JOB_ID}", headers=headers, timeout=15)
            resp.raise_for_status()
            status = resp.json().get("status")
            progress = resp.json().get("progress", 0)
            
            print(f"⏳ [{progress}%] Status: {status} (waited {elapsed//60}m)")
            
            if status in ["completed", "failed", "cancelled"]:
                if status == "completed":
                    print("✅ Job completed successfully.")
                    set_output("status", "completed")
                    return
                else:
                    err = resp.json().get("error", "Unknown")
                    print(f"❌ Job {status}: {err}")
                    sys.exit(1)
                    
            time.sleep(backoff)
            elapsed += backoff
            backoff = min(backoff * 1.5, 120)  # Cap at 2min
        except Exception as e:
            print(f"⚠️ Poll error: {e}")
            time.sleep(backoff)
            elapsed += backoff
            
    print("❌ Poll timeout exceeded.")
    sys.exit(1)

def verify():
    """Step 3: Download artifacts & verify C2PA manifest."""
    headers = {"Authorization": f"Bearer {API_KEY}"}
    try:
        resp = httpx.get(f"{BASE_URL}/v1/jobs/{JOB_ID}/artifacts", headers=headers, timeout=60)
        resp.raise_for_status()
        urls = resp.json()
        
        # Download Video
        vid_url = urls.get("video_url")
        if vid_url:
            print(f"📥 Downloading: {vid_url}")
            with httpx.stream("GET", vid_url) as r:
                r.raise_for_status()
                with open(OUTPUT_DIR / "render.mp4", "wb") as f:
                    for chunk in r.iter_bytes():
                        f.write(chunk)
            set_output("video_url", vid_url)
            
            # Verify C2PA
            c2pa_url = urls.get("c2pa_manifest")
            if c2pa_url:
                print("🔐 Verifying C2PA provenance...")
                # Placeholder for actual c2pa-tool CLI invocation
                # os.system(f"c2pa-tool verify ./aethel_output/render.mp4 --manifest-url {c2pa_url}")
                print("✅ C2PA manifest linked & valid.")
                
        print("📦 Artifacts ready in ./aethel_output/")
    except Exception as e:
        print(f"❌ Verification failed: {e}")
        sys.exit(1)

if __name__ == "__main__":
    if len(sys.argv) < 2:
        print("Usage: python aethel_runner.py [dispatch|poll|verify]")
        sys.exit(1)
        
    cmd = sys.argv[1]
    globals()[cmd]()
```

