  "operation": "synthesize_voice",
  "parameters": {
    "voice_type": "acoustic_design",
    "acoustic_design": {
      "base_timbre": "baritone",
      "prompt_text": "🧬 VOCAL ANATOMY: Elongated pharynx, hollow chest resonance. 🔊 MATERIAL: Guttural texture, fur-dampened highs. 🌌 HARMONICS: 1 layer, slight sub-bass rumble. 🎭 PERFORMANCE: Weary, protective.",
      "harmonic_layers": 1,
      "sub_bass_resonance": 0.7,
      "breath_modulation": 0.4,
      "spectral_filters": ["stone_friction"],
      "negative_prompt": "no metallic clipping, no popping, no background music, consistent timbre"
    },
    "prosody_settings": {
      "pitch_variation": 0.8,
      "tempo_multiplier": 0.85
    }
  }
}
```

