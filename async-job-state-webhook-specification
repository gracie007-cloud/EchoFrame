## 🛠️ Consumer Implementation

### Node.js / Express (TypeScript + Zod)
```typescript
import express, { Request, Response } from 'express';
import crypto from 'crypto';
import { z } from 'zod';

const WEBHOOK_SECRET = process.env.AETHEL_WEBHOOK_SECRET!;
const app = express();
app.use(express.json({ limit: '2mb' }));

// Idempotency cache (Redis/Redis-compatible recommended)
const processedEvents = new Map<string, number>();

const webhookSchema = z.object({
  id: z.string(),
  type: z.string(),
  time: z.string().datetime(),
  data: z.record(z.unknown())
});

app.post('/webhooks/aethel', async (req: Request, res: Response) => {
  const sig = req.headers['x-aethel-signature'] as string;
  const ts = req.headers['x-aethel-timestamp'] as string;
  const body = JSON.stringify(req.body);

  // 1. Verify Timing
  if (Math.abs(Date.now() / 1000 - Number(ts)) > 300) {
    return res.status(400).json({ error: 'Timestamp expired' });
  }

  // 2. Verify Signature
  const expected = `v1=sha256=${crypto.createHmac('sha256', WEBHOOK_SECRET)
    .update(`${ts}.${body}`).digest('hex')}`;
  if (!crypto.timingSafeEqual(Buffer.from(sig), Buffer.from(expected))) {
    return res.status(401).json({ error: 'Invalid signature' });
  }

  // 3. Validate Schema & Idempotency
  const event = webhookSchema.parse(req.body);
  if (processedEvents.has(event.id)) return res.status(200).end();
  processedEvents.set(event.id, Date.now());

  // 4. Route Event
  try {
    switch (event.type) {
      case 'job.completed':
        await handleJobComplete(event.data);
        break;
      case 'job.failed':
        await handleJobFailure(event.data);
        break;
      case 'job.progress':
        // Optional: Update UI/DB, do not block response
        console.log(`Progress: ${event.data.progress_pct}%`);
        break;
    }
    res.status(200).end();
  } catch (err) {
    // Critical consumer error → let retry happen
    console.error('Consumer handler failed:', err);
    res.status(500).end();
  }
});
```

### Python / FastAPI (Pydantic v2)
```python
from fastapi import FastAPI, Request, Header, HTTPException
import hmac, hashlib, time, os
from pydantic import BaseModel

app = FastAPI()
SECRET = os.getenv("AETHEL_WEBHOOK_SECRET")

class WebhookEvent(BaseModel):
    id: str
    type: str
    time: str
    data: dict

@app.post("/webhooks/aethel")
async def handle_webhook(req: Request, x_aethel_timestamp: str = Header(...), x_aethel_signature: str = Header(...)):
    body = await req.body()
    ts = x_aethel_timestamp.decode()
    if abs(time.time() - float(ts)) > 300:
        raise HTTPException(400, "Expired timestamp")
        
    msg = f"{ts}.{body.decode()}"
    expected = f"v1=sha256={hmac.new(SECRET.encode(), msg.encode(), hashlib.sha256).hexdigest()}"
    if not hmac.compare_digest(x_aethel_signature, expected):
        raise HTTPException(401, "Invalid signature")
        
    event = WebhookEvent.model_validate_json(body)
    # Idempotency check omitted for brevity (use Redis/DB)
    
    if event.type == "job.completed":
        await process_completion(event.data)
    elif event.type == "job.failed":
        await process_failure(event.data)
        
    return {"status": "received"}
```

