## 🐍 4. Bridge Script (`ci/story_graph_bridge.py`)

This script sits between raw data ingestion and the SDK dispatcher. It validates the graph, applies pacing constraints, and outputs a CI-ready payload.

```python
#!/usr/bin/env python3
# ci/story_graph_bridge.py
import json, sys, os, httpx
from pathlib import Path
from pydantic import BaseModel, ValidationError

GRAPH_SCHEMA_PATH = "config/story_graph_v1.schema.json"
OUTPUT_PAYLOAD = "config/render-payload.json"

class StoryGraphV1(BaseModel):
    story_graph_v1: dict  # Replace with strict Pydantic model for prod

def load_or_generate_graph() -> dict:
    """Call Story Graph API or load cached JSON."""
    graph_path = Path("data/story_graph.json")
    if graph_path.exists():
        with open(graph_path) as f: return json.load(f)
        
    # Fallback: Call NLP microservice
    resp = httpx.post(os.getenv("STORY_GRAPH_API_URL"), json={"sources": ["raw_text.txt"]})
    resp.raise_for_status()
    graph = resp.json()
    graph_path.write_text(json.dumps(graph, indent=2))
    return graph

def build_sdk_payload(graph: dict) -> dict:
    """Map Story Graph to AethelFrame SDK Command."""
    arc = graph["story_graph_v1"]["narrative_arc"]
    beats = arc["pacing_beats"]
    directives = graph["story_graph_v1"]["scene_directives"]
    
    return {
        "meta": {"execution_mode": "async", "priority": "high"},
        "operation": "generate_script",
        "parameters": {
            "@op": "generate_script",
            "length_seconds": sum(b["duration_pct"] for b in beats) * 10,  # Scale to seconds
            "tone_profile": beats[0]["tone"],
            "story_graph_weights": {"causality_priority": 0.8, "emotional_arc_weight": 0.6},
            "override_prompt": json.dumps(arc),
            "scene_markers": directives.get("broll_markers", []),
            "ik_triggers": directives.get("gesture_cues", [])
        }
    }

if __name__ == "__main__":
    try:
        raw = load_or_generate_graph()
        validated = StoryGraphV1.model_validate(raw)
        payload = build_sdk_payload(validated.model_dump())
        Path(OUTPUT_PAYLOAD).write_text(json.dumps(payload, indent=2))
        print(f"✅ Bridge complete. Payload saved to {OUTPUT_PAYLOAD}")
    except ValidationError as e:
        print(f"❌ Story Graph Validation Failed:\n{e.json()}")
        sys.exit(1)
```

