            ">> APPLYING POST-PROCESS FILTERS...",
            ">> ENCODING VIDEO STREAM...",
            ">> FINALIZING FILE..."
        ];

        let step = 0;
        let progress = 0;
        const interval = setInterval(() => {
            progress += Math.random() * 2;
            if(progress > 100) progress = 100;
            progressEl.style.width = progress + '%';
            
            // Update status at intervals
            if (progress > (step+1) * (100/steps.length) && step < steps.length) {
                statusEl.textContent = steps[step];
                step++;
            }

            if (progress >= 100) {
                clearInterval(interval);
                statusEl.textContent = ">> RENDER COMPLETE. SAVING TO /OUTPUT/...";
                setTimeout(() => {
                    this.log(`SUCCESS: VIDEO GENERATED AT /videos/${state.character.name.replace(/\s/g,'_')}_doc.mp4`);
                    state.isRendering = false;
                    this.renderScreen('MAIN_MENU');
