        const chars = "█▓▒░╬╫╪┼┤┬┴┌┐└┘├─│";
        const el = this.screenEl.children[Math.floor(Math.random() * this.screenEl.children.length)];
        if (!el) return;
        const original = el.textContent;
        let newText = '';
        for(let i=0; i<original.length; i++) {
            if(Math.random() > 0.95) {
                newText += chars[Math.floor(Math.random()*chars.length)];
            } else {
                newText += original[i];
            }
        }
        el.textContent = newText;
        // Revert after a short delay
        setTimeout(() => {
            if(el.parentNode) el.textContent = original;
        }, 100);
    }
